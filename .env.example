APP_NAME="Prise en charge Boutique"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# En production, mettre APP_ENV=production, APP_DEBUG=false et surtout APP_URL en https://
# (jamais http://) : sinon les liens envoyés par email (réinitialisation de mot de passe,
# vérification…) seront générés en http:// même si le site est servi en https.
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=prise_en_charge_boutique
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# SSO Microsoft 365 : renseigner l'ID du tenant Azure AD (jamais "common",
# qui ouvrirait la connexion à n'importe quel compte Microsoft).
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT=
AZURE_REDIRECT_URI="${APP_URL}/auth/azure/callback"

# Secret de l'URL /cron/{CRON_SECRET}, qui déclenche le planificateur (schedule:run) pour
# les hébergements sans accès crontab (ex. Infomaniak mutualisé) — voir le README, section
# "Traitement des emails en file d'attente". Générez une valeur aléatoire avec :
#   php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
# Laissez vide pour désactiver complètement l'endpoint (il répond alors 404 dans tous les cas).
CRON_SECRET=

VITE_APP_NAME="${APP_NAME}"
